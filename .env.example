# Copy this file to .env and fill in your own values
# cp .env.example .env

# API Keys
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Google Tasks (OAuth 2.0)
# Get credentials from https://console.cloud.google.com/
# Enable the "Google Tasks API", create Web Application OAuth credentials,
# and add http://127.0.0.1:7070/api/tasks/google/callback as a Redirect URI.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Automation Webhooks (optional)
# Add any number of webhooks using the pattern AUTOMATION_WEBHOOK_<NAME>=<url>
# Example:
# AUTOMATION_WEBHOOK_LIGHTS_ON=https://your-server/hook/lights-on
# AUTOMATION_WEBHOOK_LIGHTS_OFF=https://your-server/hook/lights-off
# Optional bearer token sent with every automation webhook request:
# AUTOMATION_API_KEY=your-optional-bearer-token

# Paths
VOSK_MODEL_PATH=/path/to/vosk-model-small-en-us-0.15
